import csv

f=open("students.csv", "a",newline='' )
w=csv.writer(f)
n= int(input(" enter the number of the students you want :"))
for x in range(n):
    name=input(" enter the name of the student:")
    phone_number=int(input(" enter the phone number :"))
    email_id =input(" enter the email id of the student:")
    l=[name,phone_number,email_id]
    w.writerow(l)
f.close()
f=open("students.csv", "r",newline='')
students=csv.read(f)
for i in students:
    print(i)
f.close
